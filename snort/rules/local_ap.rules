)

#ssh brute force from non admin from home net 


alert tcp !$ADMIN_IP any -> $HOME_GATEWAY 22 (
msg:" SSH bruteforce from non admin comming from home net detected "; 
flags:S;
detection_filter:track by_src , count 10, seconds 10;
sid:100000113;
rev:3;
)

