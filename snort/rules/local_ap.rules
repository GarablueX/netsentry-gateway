alert icmp !$ADMIN_IP any  -> $NETSENTRY_GATEWAY any (
msg:" ICMP ping from non-admin";
sid:10000001;
rev:1;
)

alert tcp !$ADMIN_IP any  -> $NETSENTRY_GATEWAY 22 (
msg:" SSH brute force non-admin";
flags:S;
detection_filter:track by_src , count 10 , seconds 60;
sid:10000002;
rev:3;
)


alert tcp !$ADMIN_IP any -> $NETSENTRY_GATEWAY 22 (
msg:" SSH SYN from  non-admin";
flags:S;
sid:10000003;
rev:2;
)


alert tcp !$ADMIN_IP any -> $NETSENTRY_GATEWAY 3001 (
msg:" AD-GUARD access non-admin";
flags:S;
sid:10000004;
rev:2;
)

alert tcp !$ADMIN_IP any -> $NETSENTRY_GATEWAY 5050 (
msg:" Non admin hitting old dashboard port ";
flags:S;
sid:10000005;
rev:1;
)


alert tcp !$ADMIN_IP any  -> $NETSENTRY_GATEWAY 5051 (
msg:" Non admin hitting old API  port ";
flags:S;
sid:10000006;
rev:1;
)




alert tcp !$ADMIN_IP any -> $NETSENTRY_GATEWAY 5050 (
msg:" Non admin hitting old test http  port ";
flags:S;
sid:10000007;
rev:1;
)


alert http !$ADMIN_IP any  -> $NETSENTRY_GATEWAY any (
msg:" Non-admin path /admin Request ";
http_uri;
content:"/admin";
sid:10000008;
rev:2;
)






