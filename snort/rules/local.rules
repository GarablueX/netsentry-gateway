alert icmp !192.168.1.11 any -> 192.168.1.17 any (

msg:"Netsentry ICMP ping detected";
sid:10000001;
rev:1;

)


alert tcp !192.168.1.11  any -> 192.168.1.17  22 (

msg:" SSH SCAN/Brute-force potentional detected  ";
flags:S;
detection_filter:track by_src , count 10 ,seconds 60;
sid:10000003;
rev:2;

)


alert tcp !192.168.1.11  any -> 192.168.1.17  22 (

msg:" SSH  Connection attempt From no Admin detected  ";
flags:S;
sid:10000002;
rev:2;

) 

alert tcp !192.168.1.11  any -> 192.168.1.17  3001 (

msg:"AD-Guard UI access attempt ";
flags:S;
sid:10000004;
rev:3;

)


alert udp !192.168.1.11  any -> 192.168.1.17  53 (

msg:"AD-Guard DNS query  ";
sid:10000005;
rev:1;
)



alert tcp !192.168.1.11  any -> 192.168.1.17  5050 (

msg:"HTTP-Dashboard aacess from non admin detected ";
sid:10000006;
rev:6;
)


alert tcp !192.168.1.11 any -> 192.168.1.17 8081 (

msg:" Non admin http test service acess detected "; 
flags:S;
sid:10000009;
rev:1;

)
 
alert http any any -> 192.168.1.17 8081 (

msg:"  NETSENTRY SUSPECIOUS http path/admin detected";
http_uri;
content:"/admin";
sid:10000010;
rev:1;

)


alert http any any -> 192.168.1.17 8081 (

msg:"  NETSENTRY SUSPECIOUS http path/login detected";
http_uri;
content:"/login";
sid:10000011;
rev:1;

)



alert http any any -> 192.168.1.17 8081 (

msg:"  NETSENTRY SUSPECIOUS http path/.env detected";
http_uri;
content:"/.env";
sid:10000012;
rev:1;

)




alert http any any -> 192.168.1.17 8081 (

msg:"  NETSENTRY SUSPECIOUS http path/wep login  detected";
http_uri;
content:"/wp-login.php";
sid:10000013;
rev:1;

